FROM node:22

WORKDIR /app

ARG BUILD_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db?schema=public
ARG BUILD_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/app_db?schema=public

COPY package*.json ./
RUN npm ci --ignore-scripts

COPY . .
RUN DATABASE_URL=$BUILD_DATABASE_URL DIRECT_URL=$BUILD_DIRECT_URL npm run postinstall \
  && DATABASE_URL=$BUILD_DATABASE_URL DIRECT_URL=$BUILD_DIRECT_URL npm run build

EXPOSE 3000

CMD ["sh", "-c", "npx prisma migrate deploy && node .output/server/index.mjs"]
